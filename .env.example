# Postora frontend environment variables (example)
# Copy this file to `.env` and fill in real values. Never commit the real `.env`.
#
# URLs:
#   - Testing app:  https://new.postora.cloud
#   - Final app:    https://postora.cloud   (cutover target — update APP_ORIGIN at final cutover)
#   - Supabase API: https://supabase.postora.cloud  (stays the same across the cutover)

# Supabase API base URL (self-hosted Supabase / Kong gateway)
VITE_SUPABASE_URL=https://supabase.postora.cloud

# Supabase Studio (admin dashboard) base URL — public, no secret.
VITE_SUPABASE_STUDIO_URL=https://supabase.postora.cloud

# Supabase publishable key (the self-hosted anon/publishable JWT). Vite-exposed (VITE_ prefix).
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SELF_HOSTED_SUPABASE_ANON_KEY

# Deployment origins (for deployment-time reference; not Vite-exposed unless prefixed VITE_)
PUBLIC_APP_ORIGIN=https://new.postora.cloud
PUBLIC_API_ORIGIN=https://supabase.postora.cloud
